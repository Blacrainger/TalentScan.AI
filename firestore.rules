rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: {sessionId}
    // Fields:
    //   - jdText: string (required) - The job description text
    //   - timestamp: timestamp (required) - The date and time of the session
    //   - uid: string (required) - The user ID of the creator
    //   - results: list (required) - Array of CandidateResult maps
    //
    // CandidateResult Map:
    //   - fileName: string (required)
    //   - score: number (required)
    //   - aiSummary: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abubakar.bana@aun.edu.ng" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidSession(data) {
      return hasRequiredFields(['jdText', 'timestamp', 'uid', 'results']) &&
             data.jdText is string && data.jdText.size() > 0 && data.jdText.size() < 50000 &&
             data.timestamp is timestamp &&
             data.uid is string &&
             data.results is list && data.results.size() <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidSession(request.resource.data) && (isOwner(request.resource.data.uid) || isAdmin());
      allow update: if isAuthenticated() && isValidSession(request.resource.data) && (isDocOwner() || isAdmin()) && uidUnchanged();
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin();
    }
  }
}
